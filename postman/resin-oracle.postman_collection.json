          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "states",
            "ZZ"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('returns 404', function () {",
              "  pm.response.to.have.status(404);",
              "});",
              "pm.test('returns state not found code', function () {",
              "  pm.expect(pm.response.json().error).to.eql('STATE_NOT_FOUND');",
              "});"
            ]
          }
        }
      ]
    },
    {
