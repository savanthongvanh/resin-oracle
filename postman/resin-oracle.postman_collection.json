          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('returns 400', function () {",
              "  pm.response.to.have.status(400);",
              "});",
              "pm.test('returns invalid code error', function () {",
              "  pm.expect(pm.response.json().error).to.eql('INVALID_STATE_ABBREVIATION');",
              "});"
